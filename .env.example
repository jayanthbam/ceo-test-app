# Copy to .env and fill in. VITE_ prefix is required for Vite to expose these
# to the client-side bundle.

# URL of the Go ceo-test-server (e.g., https://your-app.onrender.com)
VITE_GO_BACKEND_URL=https://your-render-service.onrender.com

# Shared secret — must match INTERNAL_SECRET in the Go service's env
VITE_INTERNAL_SECRET=replace-with-the-same-secret-as-render
